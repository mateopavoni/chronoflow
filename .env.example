# ───── Backend (apps/api) ─────
# Postgres (coincide con docker-compose)
DATABASE_URL=postgresql+asyncpg://chronoflow:chronoflow@localhost:5432/chronoflow
# CORS: orígenes del frontend permitidos (coma-separados)
CORS_ORIGINS=http://localhost:5173
# Entorno: dev | prod
ENV=dev

# ───── Postgres (docker-compose) ─────
POSTGRES_USER=chronoflow
POSTGRES_PASSWORD=chronoflow
POSTGRES_DB=chronoflow

# ───── Frontend (apps/web) ─────
# Base URL de la API (sin /api). El cliente agrega /api y /api/ws.
VITE_API_URL=http://localhost:8000
