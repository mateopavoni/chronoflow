# ───── Backend (apps/api) ─────
# Postgres (coincide con docker-compose)
DATABASE_URL=postgresql+asyncpg://chronoflow:chronoflow@localhost:5432/chronoflow
# CORS: orígenes del frontend permitidos (coma-separados)
CORS_ORIGINS=http://localhost:5173
# Entorno: dev | prod
ENV=dev
# Auth: secret de firma del JWT. OBLIGATORIO en prod (la app no bootea con el
# default si ENV=prod). Generá uno robusto: `openssl rand -hex 32`
JWT_SECRET=dev-insecure-secret-change-me
# Minutos de validez del token de sesión
JWT_EXPIRE_MINUTES=60

# ───── Postgres (docker-compose) ─────
POSTGRES_USER=chronoflow
POSTGRES_PASSWORD=chronoflow
POSTGRES_DB=chronoflow

# ───── Frontend (apps/web) ─────
# Base URL de la API (sin /api). El cliente agrega /api y /api/ws.
VITE_API_URL=http://localhost:8000
